# IncludEd — Root .env (Docker Compose orchestration)
# ─────────────────────────────────────────────────────────────────────────────
# This file is used by docker-compose.yml.
# Service-specific overrides live in backend/.env, frontend/.env, ai-service/.env

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=nkubana
POSTGRES_DB=included_literature
# External port (internal is 5432)
POSTGRES_PORT=5433

# ── MongoDB ───────────────────────────────────────────────────────────────────
MONGO_PORT=27017
MONGODB_URI=mongodb://localhost:27017/included_telemetry

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379

# ── Backend ───────────────────────────────────────────────────────────────────
BACKEND_PORT=3000
DATABASE_URL=postgresql://postgres:nkubana@localhost:5433/included_literature
JWT_SECRET=nQeCugxbEmV413vJOqd3bkOrDHS/V0tSiBu8/7fHBahLNtYdp/F0S1J0rexDg7hJ
JWT_EXPIRES_IN=7d
FRONTEND_URL=http://localhost:8080
AI_SERVICE_URL=http://localhost:8082

# ── AI Service ────────────────────────────────────────────────────────────────
AI_SERVICE_PORT=8082
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# ── Frontend ──────────────────────────────────────────────────────────────────
VITE_PORT=8080
VITE_API_URL=http://localhost:3000
